generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model attempt_answers {
  id         String    @id
  attemptId  String
  questionId String
  answer     Json
  isCorrect  Boolean?
  points     Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  attempts   attempts  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questions  questions @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
}

model attempts {
  id              String            @id
  userId          String
  moduleId        String
  startedAt       DateTime          @default(now())
  completedAt     DateTime?
  score           Int?
  maxScore        Int?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  attempt_answers attempt_answers[]
  users           users             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model choices {
  id         String    @id
  questionId String
  text       String
  isCorrect  Boolean   @default(false)
  order      Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  questions  questions @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model courses {
  id          String    @id
  title       String
  description String?
  slug        String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  modules     modules[]
}

model modules {
  id          String      @id
  courseId    String
  title       String
  description String?
  slug        String
  order       Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime
  courses     courses     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress    progress[]
  questions   questions[]

  @@unique([courseId, slug])
}

model progress {
  id                      String   @id
  userId                  String
  moduleId                String
  status                  String
  completionRate          Float    @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime
  module                  modules  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user                    users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
}

model questions {
  id              String            @id
  moduleId        String
  text            String
  type            String
  order           Int
  explanation     String?
  points          Int               @default(1)
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  attempt_answers attempt_answers[]
  choices         choices[]
  modules         modules           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model users {
  id        String     @id @db.Uuid
  email     String     @unique
  firstName String?
  lastName  String?
  paidAt    DateTime?  @db.Timestamptz(6)
  stripeCheckoutSessionId String? @unique
  createdAt DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt DateTime   @db.Timestamptz(6)
  attempts  attempts[]
  progress  progress[]

  // Learning state relationships
  enrollments           user_course_enrollments[]
  courseProgress        user_course_progress?
  moduleProgress        user_module_progress[]
  sectionState          user_section_state[]
  quizAttempts          user_quiz_attempts[]
  bookingBoxSubmissions booking_box_submissions[]
}

// ============================================================================
// LEARNING STATE MODELS (Normalized schema for AI course tracking)
// ============================================================================

model user_course_enrollments {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("id")
  userId     String   @unique @db.Uuid @map("user_id")
  courseSlug String   @default("ai-course") @map("course_slug")
  hasPaid    Boolean  @default(false) @map("has_paid")
  enrolledAt DateTime @default(now()) @map("enrolled_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_course_enrollments")
}

model user_course_progress {
  userId               String   @id @db.Uuid @map("user_id")
  courseSlug           String   @default("ai-course") @map("course_slug")
  currentModule        String?  @map("current_module")
  currentSection       String?  @map("current_section")
  modulesCompleted     Int      @default(0) @map("modules_completed")
  totalModules         Int      @default(5) @map("total_modules")
  completionPercentage Decimal  @default(0) @db.Decimal(5, 2) @map("completion_percentage")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_course_progress")
}

model user_module_progress {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("id")
  userId            String   @db.Uuid @map("user_id")
  moduleId          String   @map("module_id")
  status            String   @default("not_started")
  sectionsCompleted Int      @default(0) @map("sections_completed")
  totalSections     Int?     @map("total_sections")
  quizPassed        Boolean  @default(false) @map("quiz_passed")
  quizScore         Int?     @map("quiz_score")
  quizAttempts      Int      @default(0) @map("quiz_attempts")
  startedAt         DateTime? @map("started_at")
  completedAt       DateTime? @map("completed_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([userId, status])
  @@index([moduleId])
  @@map("user_module_progress")
}

model user_section_state {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("id")
  userId           String   @db.Uuid @map("user_id")
  moduleId         String   @map("module_id")
  sectionId        String   @map("section_id")
  isCompleted      Boolean  @default(false) @map("is_completed")
  timeSpentSeconds Int      @default(0) @map("time_spent_seconds")
  lastViewedAt     DateTime? @map("last_viewed_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId, sectionId])
  @@index([userId, moduleId, isCompleted])
  @@map("user_section_state")
}

model user_quiz_attempts {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("id")
  userId         String   @db.Uuid @map("user_id")
  moduleId       String   @map("module_id")
  attemptNumber  Int      @default(1) @map("attempt_number")
  score          Int
  totalQuestions Int      @map("total_questions")
  passed         Boolean  @default(false)
  answers        Json     @default("{}")
  attemptedAt    DateTime @default(now()) @map("attempted_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, moduleId])
  @@index([userId, attemptedAt])
  @@map("user_quiz_attempts")
}

model booking_box_submissions {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("id")
  userId     String?  @db.Uuid @map("user_id")
  name       String
  email      String
  message    String
  status     String   @default("new")
  sourcePage String?  @map("source_page")
  ipAddress  String?  @db.Inet @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user users? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([status, createdAt])
  @@index([userId])
  @@map("booking_box_submissions")
}
