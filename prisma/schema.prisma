generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model attempt_answers {
  id         String    @id
  attemptId  String
  questionId String
  answer     Json
  isCorrect  Boolean?
  points     Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  attempts   attempts  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questions  questions @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
}

model attempts {
  id              String            @id
  userId          String
  moduleId        String
  startedAt       DateTime          @default(now())
  completedAt     DateTime?
  score           Int?
  maxScore        Int?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  attempt_answers attempt_answers[]
  users           users             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model choices {
  id         String    @id
  questionId String
  text       String
  isCorrect  Boolean   @default(false)
  order      Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  questions  questions @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model courses {
  id          String    @id
  title       String
  description String?
  slug        String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  modules     modules[]
}

model modules {
  id          String      @id
  courseId    String
  title       String
  description String?
  slug        String
  order       Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime
  courses     courses     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress    progress[]
  questions   questions[]

  @@unique([courseId, slug])
}

model progress {
  id                      String   @id
  userId                  String
  moduleId                String
  status                  String
  completionRate          Float    @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime
  module                  modules  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user                    users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
}

model questions {
  id              String            @id
  moduleId        String
  text            String
  type            String
  order           Int
  explanation     String?
  points          Int               @default(1)
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  attempt_answers attempt_answers[]
  choices         choices[]
  modules         modules           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model users {
  id        String     @id
  email     String     @unique
  firstName String?
  lastName  String?
  paidAt    DateTime?
  stripeCheckoutSessionId String? @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime
  attempts  attempts[]
  progress  progress[]
}
