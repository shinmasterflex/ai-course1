generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model attempt_answers {
  id         String    @id
  attemptId  String
  questionId String
  answer     Json
  isCorrect  Boolean?
  points     Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  attempts   attempts  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questions  questions @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
}

model attempts {
  id              String            @id
  userId          String
  moduleId        String
  startedAt       DateTime          @default(now())
  completedAt     DateTime?
  score           Int?
  maxScore        Int?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  attempt_answers attempt_answers[]
  users           users             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model choices {
  id         String    @id
  questionId String
  text       String
  isCorrect  Boolean   @default(false)
  order      Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  questions  questions @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model courses {
  id          String    @id
  title       String
  description String?
  slug        String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  modules     modules[]
}

model modules {
  id          String      @id
  courseId    String
  title       String
  description String?
  slug        String
  order       Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime
  courses     courses     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress    progress[]
  questions   questions[]

  @@unique([courseId, slug])
}

model progress {
  id                      String   @id
  userId                  String
  moduleId                String
  status                  String
  completionRate          Float    @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime
  module                  modules  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user                    users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
}

model questions {
  id              String            @id
  moduleId        String
  text            String
  type            String
  order           Int
  explanation     String?
  points          Int               @default(1)
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  attempt_answers attempt_answers[]
  choices         choices[]
  modules         modules           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model users {
  id        String     @id
  email     String     @unique
  firstName String?
  lastName  String?
  paidAt    DateTime?
  stripeCheckoutSessionId String? @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime
  attempts  attempts[]
  progress  progress[]

  // Learning state relationships
  enrollments           user_course_enrollments[]
  courseProgress        user_course_progress?
  moduleProgress        user_module_progress[]
  sectionState          user_section_state[]
  quizAttempts          user_quiz_attempts[]
}

// ============================================================================
// LEARNING STATE MODELS (Normalized schema for AI course tracking)
// ============================================================================

model user_course_enrollments {
  id         String   @id @default(cuid())
  userId     String   @unique
  courseSlug String   @default("ai-course")
  hasPaid    Boolean  @default(false)
  enrolledAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseSlug])
}

model user_course_progress {
  userId               String   @id
  courseSlug           String   @default("ai-course")
  currentModule        String?
  currentSection       String?
  modulesCompleted     Int      @default(0)
  totalModules         Int      @default(5)
  completionPercentage Decimal  @default(0) @db.Numeric(5, 2)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model user_module_progress {
  id               String   @id @default(cuid())
  userId           String
  moduleId         String
  status           String   @default("not_started") // not_started | in_progress | completed
  sectionsCompleted Int     @default(0)
  totalSections    Int?
  quizPassed       Boolean  @default(false)
  quizScore        Int?
  quizAttempts     Int      @default(0)
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([userId, status])
  @@index([moduleId])
}

model user_section_state {
  id               String   @id @default(cuid())
  userId           String
  moduleId         String
  sectionId        String
  isCompleted      Boolean  @default(false)
  timeSpentSeconds Int      @default(0)
  lastViewedAt     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId, sectionId])
  @@index([userId, moduleId, isCompleted])
}

model user_quiz_attempts {
  id              String   @id @default(cuid())
  userId          String
  moduleId        String
  attemptNumber   Int      @default(1)
  score           Int
  totalQuestions  Int
  passed          Boolean  @default(false)
  answers         Json     @default("{}")
  attemptedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, moduleId])
  @@index([userId, attemptedAt])
}
